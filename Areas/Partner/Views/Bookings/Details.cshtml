@model HearMeStay.Models.Booking
@{ ViewData["Title"] = "Chi tiết đặt phòng & AI Insight"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="hms-section-title mb-0">Booking #@Model.BookingCode</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>

<div class="row g-4">
    <!-- Cột trái: Thông tin Booking & Khách -->
    <div class="col-lg-5">
        <div class="hms-form-section p-4 h-100">
            <h5 class="fw-bold mb-3 border-bottom pb-2"><i class="bi bi-person me-2" style="color:var(--teal);"></i>Thông tin khách</h5>
            <p class="mb-1"><strong>Họ tên:</strong> @Model.GuestFullName</p>
            <p class="mb-1"><strong>Email:</strong> @Model.GuestEmail</p>
            <p class="mb-1"><strong>SĐT:</strong> @Model.GuestPhone</p>
            
            <h5 class="fw-bold mb-3 mt-4 border-bottom pb-2"><i class="bi bi-door-open me-2" style="color:var(--teal);"></i>Chi tiết đặt phòng</h5>
            <p class="mb-1"><strong>Loại phòng:</strong> @Model.RoomType.Name</p>
            <p class="mb-1"><strong>Nhận phòng:</strong> @Model.CheckInDate.ToString("dd/MM/yyyy")</p>
            <p class="mb-1"><strong>Trả phòng:</strong> @Model.CheckOutDate.ToString("dd/MM/yyyy")</p>
            <p class="mb-1"><strong>Quy mô:</strong> @Model.NumberOfGuests khách · @Model.NumberOfRooms phòng</p>
            <p class="mb-1"><strong>Tổng tiền:</strong> <span class="fw-bold hms-price">@Model.TotalAmount.ToString("N0")₫</span></p>

            @if (!string.IsNullOrEmpty(Model.GuestNote) || (Model.GuestPreference != null && !string.IsNullOrEmpty(Model.GuestPreference.RawText)))
            {
                <h5 class="fw-bold mb-2 mt-4"><i class="bi bi-pencil me-2" style="color:var(--teal);"></i>Ghi chú của khách</h5>
                <div class="p-3 bg-light rounded text-muted small" style="border-left:3px solid var(--teal);">
                    @if(!string.IsNullOrEmpty(Model.GuestNote)){<p class="mb-1">@Model.GuestNote</p>}
                    @if(Model.GuestPreference != null && !string.IsNullOrEmpty(Model.GuestPreference.RawText)){<p class="mb-0"><strong>Nhu cầu:</strong> @Model.GuestPreference.RawText</p>}
                </div>
            }
        </div>
    </div>

    <!-- Cột phải: AI Insight & Xác nhận -->
    <div class="col-lg-7">
        @if (Model.GuestPreference?.GuestInsight != null)
        {
            var insight = Model.GuestPreference.GuestInsight;
            <div class="hms-form-section p-4 mb-4" style="border: 1px solid var(--teal-pale); box-shadow: 0 4px 12px rgba(13,148,136,0.1);">
                <div class="d-flex align-items-center gap-2 border-bottom pb-2 mb-3">
                    <i class="bi bi-magic fs-4" style="color:var(--teal);"></i>
                    <h5 class="fw-bold mb-0">AI Phân tích nhu cầu</h5>
                </div>
                
                <p class="mb-3"><strong>Summary:</strong> @insight.Summary</p>
                
                <div class="mb-3">
                    <strong>Tags:</strong> 
                    @foreach(var t in insight.Tags) { <span class="badge hms-badge hms-badge-ai">@t.TagName</span> }
                </div>

                @if(insight.Tasks.Any()){
                    <div class="mb-3">
                        <strong>Nhiệm vụ cho bộ phận:</strong>
                        <ul class="mb-0 mt-1" style="font-size:0.9rem; padding-left:1.2rem;">
                            @foreach(var t in insight.Tasks){
                                <li><span class="badge bg-secondary me-1">@t.Department</span> <strong>@t.Title:</strong> @t.Description</li>
                            }
                        </ul>
                    </div>
                }

                @if(insight.UpsellSuggestions.Any()){
                    <div>
                        <strong>Gợi ý Upsell:</strong>
                        <ul class="mb-0 mt-1 text-success" style="font-size:0.9rem; padding-left:1.2rem;">
                            @foreach(var u in insight.UpsellSuggestions){
                                <li><strong>@u.Title:</strong> @u.Reason</li>
                            }
                        </ul>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-secondary">Khách hàng chưa cung cấp thêm nhu cầu cá nhân.</div>
        }

        <!-- Phần Xác nhận & Phản hồi -->
        @if (Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Pending)
        {
            <div class="hms-form-section p-4">
                <h5 class="fw-bold mb-3 border-bottom pb-2"><i class="bi bi-check-circle me-2" style="color:#059669;"></i>Xác nhận Booking</h5>
                
                <form asp-action="Confirm" method="post" class="mb-3">
                    <input type="hidden" name="id" value="@Model.Id" />
                    
                    @if (Model.GuestPreference != null)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold">Khả năng hỗ trợ yêu cầu đặc biệt</label>
                            <select name="specialRequestStatus" class="form-select">
                                <option value="CanSupport">Có thể hỗ trợ tất cả</option>
                                <option value="PartialSupport">Hỗ trợ một phần</option>
                                <option value="CannotSupport">Không thể hỗ trợ</option>
                                <option value="NeedMoreInfo">Cần thêm thông tin</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Phụ phí dịch vụ thêm (VNĐ)</label>
                            <input type="number" name="extraFee" class="form-control" value="0" min="0" step="1000" placeholder="Nhập số tiền phụ phí (nếu có)" />
                            <small class="text-muted">Nhập phí phát sinh nếu khách yêu cầu thêm dịch vụ (trang trí phòng, đưa đón,...). Số tiền này sẽ được cộng vào Tổng tiền thanh toán.</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ghi chú phản hồi cho khách</label>
                            <textarea name="partnerSpecialRequestNote" class="form-control" rows="2" placeholder="Ví dụ: Chúng tôi đã chuẩn bị phòng yên tĩnh. Phí trang trí phòng là 200.000đ đã được cộng vào tổng bill..."></textarea>
                        </div>
                    }
                    
                    <button type="submit" class="btn btn-success w-100"><i class="bi bi-check-lg me-1"></i>Xác nhận & Gửi phản hồi</button>
                </form>

                <form asp-action="Reject" method="post" onsubmit="return confirm('Bạn chắc chắn muốn từ chối booking này?');">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="mb-2">
                        <textarea name="partnerNote" class="form-control" rows="1" placeholder="Lý do từ chối (tùy chọn)"></textarea>
                    </div>
                    <button type="submit" class="btn btn-outline-danger w-100"><i class="bi bi-x-lg me-1"></i>Từ chối đặt phòng</button>
                </form>
            </div>
        }
        else if (Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.PaymentVerificationPending)
        {
            <div class="hms-form-section p-4 text-center border border-info shadow-sm" style="background-color: #f0f9ff;">
                <h5 class="fw-bold mb-3 text-info"><i class="bi bi-shield-check me-2"></i>Xác minh thanh toán</h5>
                <p>Khách hàng đã báo cáo thanh toán. Hình thức: <strong>@Model.PaymentTransferContent</strong></p>
                <div class="d-flex justify-content-center gap-2">
                    <form asp-action="VerifyPayment" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-info text-white fw-bold px-4 rounded-pill"><i class="bi bi-check-circle me-1"></i>Đã nhận được tiền & Hoàn tất</button>
                    </form>
                    <button type="button" class="btn btn-outline-danger px-3 rounded-pill" data-bs-toggle="modal" data-bs-target="#rejectPaymentModal">Chưa nhận được tiền</button>
                </div>
            </div>

            <!-- Modal từ chối thanh toán -->
            <div class="modal fade" id="rejectPaymentModal" tabindex="-1">
                <div class="modal-dialog">
                    <form asp-action="RejectPayment" method="post" class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title text-danger">Báo cáo chưa nhận được tiền</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <p class="mb-3">Khách hàng sẽ nhận được thông báo để kiểm tra lại giao dịch hoặc thực hiện thanh toán lại.</p>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Lý do (Tùy chọn)</label>
                                <textarea name="reason" class="form-control" rows="2" placeholder="Ví dụ: Kiểm tra sao kê chưa thấy tiền nổi, hoặc số tiền chuyển bị thiếu..."></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                            <button type="submit" class="btn btn-danger">Xác nhận</button>
                        </div>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="hms-form-section p-4 text-center">
                <h5 class="fw-bold">Trạng thái: 
                    <span class="badge @(Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Confirmed ? "badge-confirmed" : Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.PaymentPending ? "bg-warning text-dark" : Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Cancelled ? "badge-cancelled" : "badge-completed")">
                        @Model.BookingStatus
                    </span>
                </h5>
                @if (Model.GuestPreference != null && Model.GuestPreference.SpecialRequestStatus != HearMeStay.Models.Enums.SpecialRequestStatus.Pending)
                {
                    <p class="mt-2 mb-1"><strong>Phản hồi yêu cầu:</strong> @Model.GuestPreference.SpecialRequestStatus</p>
                    <p class="text-muted small">@Model.GuestPreference.PartnerSpecialRequestNote</p>
                }

                @if (Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Confirmed)
                {
                    <hr class="my-3">
                    <form asp-action="MarkCompleted" method="post" onsubmit="return confirm('Xác nhận khách đã hoàn tất lưu trú (Check-out) và trả phòng? Khách hàng sẽ nhận được yêu cầu đánh giá.');">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-success"><i class="bi bi-calendar-check me-1"></i>Đánh dấu đã hoàn tất lưu trú</button>
                    </form>
                }
            </div>
        }
    </div>
</div>
