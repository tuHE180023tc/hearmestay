@model List<HearMeStay.Models.AddOnService>
@{ ViewData["Title"] = "Dịch vụ cộng thêm"; }
<div class="d-flex justify-content-between mb-4"><h2 class="fw-bold">Dịch vụ cộng thêm</h2><a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus"></i> Thêm dịch vụ</a></div>
@foreach (var s in Model)
{
    <div class="card shadow-sm border-0 mb-2 p-3" style="border-radius:12px;">
        <div class="d-flex justify-content-between">
            <div>
                <strong>@s.Name</strong> — @s.Price.ToString("N0")₫
                <p class="text-muted small mb-0">@s.Description</p>
            </div>
            <div class="d-flex gap-2 align-items-start">
                <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                <form asp-action="Delete" asp-route-id="@s.Id" method="post" onsubmit="return confirm('Xóa dịch vụ này?');">
                    <button class="btn btn-sm btn-outline-danger">Xóa</button>
                </form>
            </div>
        </div>
    </div>
}
