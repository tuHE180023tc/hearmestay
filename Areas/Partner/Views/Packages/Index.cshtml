@model List<HearMeStay.Models.SubscriptionPlan>
@{ ViewData["Title"] = "Gói dịch vụ"; }
<h2 class="fw-bold mb-4">Các gói dịch vụ (Subscription)</h2>
<p class="text-muted mb-4">Nâng cấp gói dịch vụ để tận hưởng hoa hồng thấp hơn và nhiều tính năng đặc quyền giúp tăng tối đa doanh thu.</p>

<div class="row g-4">
    @foreach(var plan in Model)
    {
        var isCurrent = ViewBag.ActivePlanId == plan.Id;
        var features = string.IsNullOrEmpty(plan.Features) ? new string[0] : plan.Features.Split(',');

        <div class="col-md-4">
            <div class="card hms-stat-card h-100 p-4 border-0 shadow-sm @(isCurrent ? "border-primary border-2" : "")" style="border-radius:16px; position:relative;">
                @if (isCurrent)
                {
                    <span class="badge bg-primary position-absolute" style="top: -10px; right: 20px; font-size: 0.9rem;">Đang sử dụng</span>
                }
                
                <h4 class="fw-bold mb-3">@plan.Name</h4>
                <div class="mb-3">
                    <span class="fs-2 fw-bold hms-price">@plan.PricePerMonth.ToString("N0")₫</span>
                    <span class="text-muted">/tháng</span>
                </div>
                <div class="mb-4">
                    <span class="badge bg-success-subtle text-success px-3 py-2 fw-bold" style="font-size: 0.95rem;">Hoa hồng: @plan.CommissionRate%</span>
                </div>
                
                <ul class="list-unstyled mb-4 flex-grow-1">
                    @foreach(var feature in features)
                    {
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-primary me-2"></i> @feature.Trim()</li>
                    }
                </ul>

                @if (!isCurrent)
                {
                    <form asp-action="Upgrade" method="post">
                        <input type="hidden" name="planId" value="@plan.Id" />
                        <button type="submit" class="btn btn-outline-primary w-100 fw-bold rounded-pill">
                            @(plan.PricePerMonth == 0 ? "Chọn gói này" : "Nâng cấp ngay")
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn btn-primary w-100 fw-bold rounded-pill" disabled>Đang sử dụng</button>
                }
            </div>
        </div>
    }
</div>
