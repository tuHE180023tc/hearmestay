@model List<HearMeStay.Models.Booking>
@{ ViewData["Title"] = "Quản lý đặt phòng"; }
<h2 class="fw-bold mb-4">Quản lý đặt phòng</h2>
<table class="table table-hover bg-white rounded shadow-sm">
    <thead class="table-light"><tr><th>Mã</th><th>Khách</th><th>Nơi lưu trú</th><th>Check-in</th><th>Tổng tiền</th><th>Trạng thái</th><th>Hành động</th></tr></thead>
    <tbody>
    @foreach (var b in Model)
    {
        var st = b.BookingStatus switch { HearMeStay.Models.Enums.BookingStatus.Pending=>"Chờ xác nhận", HearMeStay.Models.Enums.BookingStatus.Confirmed=>"Đã xác nhận", HearMeStay.Models.Enums.BookingStatus.Rejected=>"Bị từ chối", HearMeStay.Models.Enums.BookingStatus.Cancelled=>"Đã hủy", HearMeStay.Models.Enums.BookingStatus.Completed=>"Đã hoàn tất", _=>"" };
        <tr>
            <td>@b.BookingCode</td>
            <td>@b.User.FullName</td>
            <td>@b.Accommodation.Name</td>
            <td>@b.CheckInDate.ToString("dd/MM/yyyy")</td>
            <td>@b.TotalAmount.ToString("N0")₫</td>
            <td>@st</td>
            <td>
                <a asp-action="Details" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a>
            </td>
        </tr>
    }
    </tbody>
</table>
