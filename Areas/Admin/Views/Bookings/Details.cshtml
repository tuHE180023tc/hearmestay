@model HearMeStay.Models.Booking
@inject HearMeStay.Data.ApplicationDbContext dbContext
@{ ViewData["Title"] = "Chi tiết đặt phòng"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="hms-section-title mb-0">Booking #@Model.BookingCode</h2>
    <div class="d-flex gap-2">
        @if (Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Confirmed || Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Completed)
        {
            <a asp-action="ExportBookingConfirmationPdf" asp-route-id="@Model.Id" class="btn btn-primary btn-sm"><i class="bi bi-file-earmark-pdf me-1"></i>Phiếu xác nhận PDF</a>
        }
        @if (Model.PaymentStatus == HearMeStay.Models.Enums.PaymentStatus.Paid || Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Confirmed || Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Completed)
        {
            <a asp-action="ExportPaymentReceiptPdf" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm"><i class="bi bi-receipt me-1"></i>Biên nhận TT</a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="hms-form-section p-4 h-100">
            <h5 class="fw-bold mb-3 border-bottom pb-2">Thông tin chung</h5>
            <p><strong>Khách hàng:</strong> @Model.User.FullName</p>
            <p><strong>Nơi lưu trú:</strong> @Model.Accommodation.Name</p>
            <p><strong>Loại phòng:</strong> @Model.RoomType.Name</p>
            <p><strong>Trạng thái:</strong> @Model.BookingStatus</p>
            
            @if(Model.GuestPreference != null)
            {
                <div class="d-flex justify-content-between align-items-center mt-4 mb-3 border-bottom pb-2">
                    <h5 class="fw-bold mb-0">Nhu cầu cá nhân</h5>
                    <a asp-action="ExportGuestInsightPdf" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-file-earmark-pdf me-1"></i>Xuất phiếu AI Insight</a>
                </div>
                <p>@Model.GuestPreference.RawText</p>
            }
        </div>
    </div>
    
    <div class="col-lg-5">
        <div class="hms-form-section p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                <h5 class="fw-bold mb-0"><i class="bi bi-clock-history me-2 text-teal"></i>Nhật ký xử lý booking</h5>
                <a asp-action="ExportOperationLogPdf" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-file-earmark-pdf me-1"></i>Xuất PDF</a>
            </div>
            <div class="mb-3 p-3 bg-light rounded" style="font-size: 0.9rem;">
                @{
                    string lastHandledByName = "Chưa có";
                    if (!string.IsNullOrEmpty(Model.LastHandledByUserId))
                    {
                        var lastUser = await dbContext.Users.FindAsync(Model.LastHandledByUserId);
                        if (lastUser != null) lastHandledByName = lastUser.FullName;
                    }
                }
                <p class="mb-1"><strong>Bước hiện tại:</strong> @(Model.CurrentStep ?? "Không có")</p>
                <p class="mb-1"><strong>Người xử lý:</strong> @lastHandledByName - @(Model.LastHandledAt?.ToString("dd/MM/yyyy HH:mm") ?? "")</p>
                <p class="mb-0 text-primary"><strong>Tiếp theo:</strong> @(Model.NextAction ?? "Chưa có")</p>
            </div>

            @if (Model.OperationLogs != null && Model.OperationLogs.Any())
            {
                <div class="timeline" style="border-left: 2px solid #e9ecef; margin-left: 10px; padding-left: 15px; position: relative;">
                    @foreach (var log in Model.OperationLogs)
                    {
                        <div class="timeline-item mb-4" style="position: relative;">
                            <div class="timeline-indicator" style="position: absolute; left: -22px; top: 0; width: 12px; height: 12px; border-radius: 50%; background-color: var(--teal);"></div>
                            <div class="text-muted small mb-1">
                                <i class="bi bi-clock me-1"></i>@log.CreatedAt.ToString("dd/MM/yyyy HH:mm") 
                                <span class="ms-2 badge bg-secondary">@log.ActorRole</span>
                            </div>
                            <div class="fw-bold">@HearMeStay.Models.Enums.BookingOperationActionTypeHelper.GetDisplayName(log.ActionType)</div>
                            @if (!string.IsNullOrEmpty(log.Note))
                            {
                                <div class="text-muted small mt-1">@log.Note</div>
                            }
                            @if (!string.IsNullOrEmpty(log.InternalNote))
                            {
                                <div class="small mt-1 p-2 bg-warning bg-opacity-10 rounded border border-warning" style="color: #856404;">
                                    <strong>Ghi chú nội bộ:</strong> @log.InternalNote
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(log.NextAction))
                            {
                                <div class="small mt-1 text-primary">
                                    <i class="bi bi-arrow-return-right me-1"></i><strong>Tiếp theo:</strong> @log.NextAction
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">Chưa có nhật ký xử lý.</p>
            }
        </div>
    </div>
</div>
