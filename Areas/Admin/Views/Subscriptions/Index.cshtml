@model List<HearMeStay.Models.SubscriptionPayment>
@{ ViewData["Title"] = "Xác minh thanh toán gói dịch vụ"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Xác minh thanh toán Gói dịch vụ</h2>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Không có thanh toán nào đang chờ xác minh.</div>
}
else
{
    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã thanh toán</th>
                        <th>Đối tác</th>
                        <th>Gói dịch vụ</th>
                        <th>Số tiền</th>
                        <th>Nội dung chuyển khoản</th>
                        <th>Thời gian báo cáo</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td><strong>#@p.Id</strong></td>
                            <td>@p.PartnerSubscription.Partner.FullName</td>
                            <td><span class="badge bg-primary">@p.PartnerSubscription.SubscriptionPlan.Name</span></td>
                            <td class="fw-bold text-success">@p.Amount.ToString("N0")₫</td>
                            <td><code>@p.PaymentTransferContent</code></td>
                            <td>@p.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end">
                                <form asp-action="Verify" method="post" class="d-inline" onsubmit="return confirm('Xác nhận đã nhận đủ tiền và kích hoạt gói?');">
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button type="submit" class="btn btn-sm btn-success">Xác nhận</button>
                                </form>
                                <form asp-action="Reject" method="post" class="d-inline" onsubmit="return confirm('Từ chối thanh toán này?');">
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">Từ chối</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
