@model HearMeStay.Models.Booking
@{ ViewData["Title"] = "Chi tiết đặt phòng"; }
<div style="padding-top:100px;"></div>
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4 fade-up">
                <h2 class="hms-section-title mb-0">Chi tiết đặt phòng #@Model.BookingCode</h2>
                <div class="d-flex gap-2">
                    @if (Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Confirmed || Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Completed)
                    {
                        <a asp-action="ExportBookingConfirmationPdf" asp-route-id="@Model.Id" class="btn btn-primary btn-sm"><i class="bi bi-file-earmark-pdf me-1"></i>Phiếu xác nhận</a>
                    }
                    @if (Model.PaymentStatus == HearMeStay.Models.Enums.PaymentStatus.Paid || Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Confirmed || Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Completed)
                    {
                        <a asp-action="ExportPaymentReceiptPdf" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm"><i class="bi bi-receipt me-1"></i>Biên nhận TT</a>
                    }
                    <a asp-action="MyBookings" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
                </div>
            </div>

            <div class="hms-form-section p-4 fade-up mb-4">
                <div class="row border-bottom pb-4 mb-4">
                    <div class="col-md-8">
                        <h5 class="fw-bold mb-1">@Model.Accommodation.Name</h5>
                        <p class="text-muted small mb-0"><i class="bi bi-geo-alt me-1"></i>@Model.Accommodation.Address, @Model.Accommodation.City</p>
                    </div>
                    <div class="col-md-4 text-md-end mt-3 mt-md-0">
                        @{ var st = Model.BookingStatus switch { HearMeStay.Models.Enums.BookingStatus.Pending=>"Chờ xác nhận", HearMeStay.Models.Enums.BookingStatus.Confirmed=>"Đã xác nhận", HearMeStay.Models.Enums.BookingStatus.Rejected=>"Bị từ chối", HearMeStay.Models.Enums.BookingStatus.Cancelled=>"Đã hủy", HearMeStay.Models.Enums.BookingStatus.Completed=>"Đã hoàn tất", HearMeStay.Models.Enums.BookingStatus.PaymentPending=>"Chờ thanh toán", HearMeStay.Models.Enums.BookingStatus.PaymentVerificationPending=>"Chờ xác minh", HearMeStay.Models.Enums.BookingStatus.PaymentExpired=>"Đã hết hạn", _=>"" };
                           var bg = Model.BookingStatus switch { HearMeStay.Models.Enums.BookingStatus.Pending=>"badge-pending", HearMeStay.Models.Enums.BookingStatus.Confirmed=>"badge-confirmed", HearMeStay.Models.Enums.BookingStatus.Rejected=>"badge-rejected", HearMeStay.Models.Enums.BookingStatus.Cancelled=>"badge-cancelled", HearMeStay.Models.Enums.BookingStatus.Completed=>"badge-completed", HearMeStay.Models.Enums.BookingStatus.PaymentPending=>"bg-warning text-dark", HearMeStay.Models.Enums.BookingStatus.PaymentVerificationPending=>"bg-info text-dark", HearMeStay.Models.Enums.BookingStatus.PaymentExpired=>"bg-secondary", _=>"" }; }
                        <span class="badge badge-status @bg px-3 py-2">@st</span>
                    </div>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6"><small class="text-muted d-block mb-1">Nhận phòng</small><strong class="fs-5">@Model.CheckInDate.ToString("dd/MM/yyyy")</strong><br><span class="text-muted small">Từ @Model.Accommodation.CheckInTime.ToString(@"hh\:mm")</span></div>
                    <div class="col-md-6"><small class="text-muted d-block mb-1">Trả phòng</small><strong class="fs-5">@Model.CheckOutDate.ToString("dd/MM/yyyy")</strong><br><span class="text-muted small">Trước @Model.Accommodation.CheckOutTime.ToString(@"hh\:mm")</span></div>
                </div>

                <div class="row g-4 mb-4 pb-4 border-bottom">
                    <div class="col-md-4"><small class="text-muted d-block mb-1">Loại phòng</small><strong>@Model.RoomType.Name</strong></div>
                    <div class="col-md-4"><small class="text-muted d-block mb-1">Khách & Phòng</small><strong>@Model.NumberOfGuests khách, @Model.NumberOfRooms phòng</strong></div>
                    <div class="col-md-4"><small class="text-muted d-block mb-1">Tổng tiền</small><strong class="hms-price fs-5">@Model.TotalAmount.ToString("N0")₫</strong></div>
                </div>

                @if (Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.PaymentPending)
                {
                    <div class="alert alert-warning mb-4 shadow-sm" style="background-color: #fff3cd; border-color: #ffe69c;">
                        <i class="bi bi-exclamation-circle-fill me-2 text-warning"></i>Nơi lưu trú đã xác nhận còn phòng. Vui lòng thanh toán để hoàn tất đặt phòng.
                    </div>
                    <div class="p-4 text-center mb-4 border border-warning shadow-sm rounded-4" style="background-color: #fffaf0;">
                        <h5 class="fw-bold mb-3" style="color: var(--navy-deep);">Thanh toán qua mã QR</h5>
                        <img src="@Model.PaymentQrImageUrl" alt="QR Code" class="img-fluid mb-3 shadow-sm" style="max-width: 250px; border: 1px solid #ddd; border-radius: 8px; padding: 10px; background: white;" />
                        <div class="mb-3">
                            <p class="mb-1 text-muted">Số tiền cần thanh toán:</p>
                            <p class="fs-3 fw-bold text-danger mb-2">@Model.TotalAmount.ToString("N0")₫</p>
                            <p class="mb-1 text-muted">Nội dung chuyển khoản:</p>
                            <p class="user-select-all fw-bold fs-5 px-3 py-2 bg-white d-inline-block border rounded" style="color: var(--navy-deep); letter-spacing: 1px;">@Model.PaymentTransferContent</p>
                        </div>
                        <p class="small text-muted mb-4"><i class="bi bi-info-circle me-1"></i>Vui lòng chuyển khoản đúng nội dung để hệ thống xác minh nhanh hơn.</p>
                        <form asp-action="SubmitPayment" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="btn btn-success btn-lg px-5 shadow-sm rounded-pill fw-bold"><i class="bi bi-check-circle me-2"></i>Tôi đã thanh toán</button>
                        </form>
                    </div>
                }
                
                @if (Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.PaymentVerificationPending)
                {
                    <div class="alert alert-info mb-4 shadow-sm">
                        <i class="bi bi-clock-history me-2"></i>Trạng thái: <strong>Chờ xác minh thanh toán</strong>. Bạn đã báo thanh toán thành công, hệ thống đang xác minh giao dịch của bạn.
                    </div>
                }

                <div class="d-flex flex-wrap gap-2 mb-3">
                    @if ((Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Confirmed || Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Pending) && Model.GuestPreference == null)
                    {
                        <a asp-controller="Preferences" asp-action="Create" asp-route-bookingId="@Model.Id" class="btn btn-primary"><i class="bi bi-chat-heart me-1"></i>Chia sẻ nhu cầu cá nhân</a>
                    }
                    else if (Model.GuestPreference != null)
                    {
                        var srText = Model.GuestPreference.SpecialRequestStatus switch { 
                            HearMeStay.Models.Enums.SpecialRequestStatus.Pending => "Đang xử lý nhu cầu",
                            HearMeStay.Models.Enums.SpecialRequestStatus.CanSupport => "Có thể hỗ trợ",
                            HearMeStay.Models.Enums.SpecialRequestStatus.PartialSupport => "Hỗ trợ một phần",
                            HearMeStay.Models.Enums.SpecialRequestStatus.CannotSupport => "Không thể hỗ trợ",
                            HearMeStay.Models.Enums.SpecialRequestStatus.NeedMoreInfo => "Cần thêm thông tin",
                            _ => ""
                        };
                        var srClass = Model.GuestPreference.SpecialRequestStatus switch { 
                            HearMeStay.Models.Enums.SpecialRequestStatus.Pending => "bg-secondary text-white",
                            HearMeStay.Models.Enums.SpecialRequestStatus.CanSupport => "bg-success text-white",
                            HearMeStay.Models.Enums.SpecialRequestStatus.PartialSupport => "bg-warning text-dark",
                            HearMeStay.Models.Enums.SpecialRequestStatus.CannotSupport => "bg-danger text-white",
                            HearMeStay.Models.Enums.SpecialRequestStatus.NeedMoreInfo => "bg-info text-dark",
                            _ => ""
                        };
                        <span class="btn btn-glass bg-light cursor-default border" style="border-color: #dee2e6;">
                            <i class="bi bi-check-circle me-1 text-success"></i>Đã gửi nhu cầu 
                            <span class="badge @srClass ms-2">@srText</span>
                        </span>
                    }

                    @if (Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Completed && Model.Review == null)
                    {
                        <a asp-controller="Reviews" asp-action="Create" asp-route-bookingId="@Model.Id" class="btn btn-warning"><i class="bi bi-star me-1"></i>Đánh giá trải nghiệm</a>
                    }

                    @if (Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.Pending || Model.BookingStatus == HearMeStay.Models.Enums.BookingStatus.PaymentPending)
                    {
                        <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline ms-auto" onsubmit="return confirm('Bạn có chắc muốn hủy đặt phòng này?');">
                            <button type="submit" class="btn btn-outline-danger"><i class="bi bi-x-lg me-1"></i>Hủy đặt phòng</button>
                        </form>
                    }
                </div>
                
                @if (Model.GuestPreference != null && !string.IsNullOrEmpty(Model.GuestPreference.PartnerSpecialRequestNote))
                {
                    <div class="alert alert-info mt-3 mb-0 border-0 shadow-sm">
                        <h6 class="fw-bold mb-1"><i class="bi bi-chat-square-text me-2"></i>Phản hồi từ nơi lưu trú:</h6>
                        <p class="mb-0 small">@Model.GuestPreference.PartnerSpecialRequestNote</p>
                    </div>
                }
            </div>
            </div>

            <!-- Traveler Timeline -->
            @if (Model.OperationLogs != null && Model.OperationLogs.Any(l => string.IsNullOrEmpty(l.InternalNote)))
            {
                <div class="hms-form-section p-4 fade-up mb-4 mt-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2"><i class="bi bi-clock-history me-2 text-primary"></i>Tiến trình xử lý</h5>
                    <div class="timeline" style="border-left: 2px solid #e9ecef; margin-left: 10px; padding-left: 15px; position: relative;">
                        @foreach (var log in Model.OperationLogs.Where(l => string.IsNullOrEmpty(l.InternalNote)).OrderByDescending(l => l.CreatedAt))
                        {
                            <div class="timeline-item mb-4" style="position: relative;">
                                <div class="timeline-indicator" style="position: absolute; left: -22px; top: 0; width: 12px; height: 12px; border-radius: 50%; background-color: var(--primary);"></div>
                                <div class="text-muted small mb-1">
                                    <i class="bi bi-clock me-1"></i>@log.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </div>
                                <div class="fw-bold">@HearMeStay.Models.Enums.BookingOperationActionTypeHelper.GetDisplayName(log.ActionType)</div>
                                @if (!string.IsNullOrEmpty(log.Note))
                                {
                                    <div class="text-muted small mt-1">@log.Note</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
