@model HearMeStay.ViewModels.AccommodationSearchViewModel
@{ ViewData["Title"] = "Tìm kiếm nơi lưu trú"; }

<style>
    body { background-color: #F7F9FA; }
    .hms-filter-sidebar {
        background: #fff;
        border-radius: var(--r);
        padding: 1.25rem;
        box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    }
    .hms-filter-section {
        border-bottom: 1px solid var(--border-light);
        padding-bottom: 1rem;
        margin-bottom: 1rem;
    }
    .hms-filter-section:last-child {
        border-bottom: none;
        padding-bottom: 0;
        margin-bottom: 0;
    }
    .hms-list-card {
        background: #fff;
        border-radius: var(--r);
        box-shadow: 0 1px 4px rgba(0,0,0,0.08);
        overflow: hidden;
        transition: box-shadow 0.2s ease;
        margin-bottom: 1rem;
        border: 1px solid transparent;
    }
    .hms-list-card:hover {
        box-shadow: 0 6px 16px rgba(0,0,0,0.12);
        border-color: rgba(13,148,136,0.3);
    }
    .hms-card-img-col {
        position: relative;
        height: 100%;
        min-height: 220px;
    }
    .hms-card-img-col img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        position: absolute;
        top: 0;
        left: 0;
    }
    .hms-score-badge {
        background: var(--teal);
        color: white;
        padding: 0.25rem 0.5rem;
        border-radius: 6px;
        font-weight: 700;
        font-size: 0.9rem;
    }
    .hms-original-price {
        text-decoration: line-through;
        color: #999;
        font-size: 0.9rem;
    }
    .hms-discount-badge {
        background: #FEE2E2;
        color: #DC2626;
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 700;
    }
    .hms-price-large {
        color: #DC2626;
        font-size: 1.4rem;
        font-weight: 800;
        line-height: 1.2;
    }
    .hms-tax-info {
        font-size: 0.75rem;
        color: #666;
    }
</style>

<div style="padding-top:100px;"></div>

<div class="container-xl mb-5">
    
    <!-- ORIGINAL STYLE SEARCH BAR -->
    <div class="hms-form-section mb-4 fade-up">
        <form method="get">
            <div class="row g-3 align-items-end">
                <div class="col-lg-3 col-md-6">
                    <label class="form-label">Điểm đến</label>
                    <input type="text" name="City" value="@Model.City" list="cityList" class="form-control" placeholder="Thành phố, tỉnh..." autocomplete="off" />
                    <datalist id="cityList">
                        <option value="Hà Nội"></option>
                        <option value="Hồ Chí Minh"></option>
                        <option value="Đà Nẵng"></option>
                        <option value="Đà Lạt"></option>
                        <option value="Nha Trang"></option>
                        <option value="Phú Quốc"></option>
                        <option value="Hạ Long"></option>
                        <option value="Vũng Tàu"></option>
                        <option value="Sapa"></option>
                        <option value="Hội An"></option>
                    </datalist>
                </div>
                <div class="col-lg-2 col-md-3"><label class="form-label">Nhận phòng</label><input type="date" name="CheckIn" value="@Model.CheckIn?.ToString("yyyy-MM-dd")" class="form-control" /></div>
                <div class="col-lg-2 col-md-3"><label class="form-label">Trả phòng</label><input type="date" name="CheckOut" value="@Model.CheckOut?.ToString("yyyy-MM-dd")" class="form-control" /></div>
                <div class="col-lg-1 col-md-2"><label class="form-label">Khách</label><input type="number" name="Guests" value="@Model.Guests" class="form-control" min="1" /></div>
                <div class="col-lg-2 col-md-4"><label class="form-label">Loại hình</label><select name="AccommodationType" class="form-select"><option value="">Tất cả</option><option value="Hotel">Khách sạn</option><option value="Homestay">Homestay</option><option value="Villa">Villa</option><option value="Resort">Resort</option><option value="Apartment">Căn hộ</option></select></div>
                <div class="col-lg-2 col-md-2"><button type="submit" class="btn btn-primary w-100"><i class="bi bi-search me-1"></i>Tìm</button></div>
            </div>
        </form>
    </div>

    <div class="row g-4">
        <!-- LEFT SIDEBAR: FILTERS -->
        <div class="col-lg-3 d-none d-lg-block fade-up">
            <!-- Map Card -->
            <div class="card mb-4 border-0" style="border-radius: var(--r); overflow:hidden;">
                <div class="position-relative" style="height: 120px; background: #E0F2FE;">
                    <img src="https://maps.gstatic.com/mapfiles/api-3/images/cb_scout5.png" alt="Map" style="opacity:0.3; object-fit:cover; width:100%; height:100%;" />
                    <div class="position-absolute top-50 start-50 translate-middle text-center w-100">
                        <i class="bi bi-geo-alt-fill text-primary" style="font-size: 2rem;"></i><br/>
                        <button class="btn btn-primary btn-sm rounded-pill fw-bold mt-1 px-3 shadow-sm">Bản đồ</button>
                    </div>
                </div>
            </div>

            <!-- Filters -->
            <div class="hms-filter-sidebar">
                <form method="get" id="filterForm">
                    <input type="hidden" name="City" value="@Model.City" />
                    <input type="hidden" name="CheckIn" value="@Model.CheckIn?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="CheckOut" value="@Model.CheckOut?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="Guests" value="@Model.Guests" />

                    <!-- Price Range -->
                    <div class="hms-filter-section">
                        <h6 class="fw-bold mb-3">Mức giá tối đa <span class="fw-normal text-muted small d-block">1 phòng, 1 đêm</span></h6>
                        <input type="range" name="PriceMax" class="form-range" min="0" max="10000000" step="500000" id="priceRange" style="accent-color: var(--teal);" value="@(Model.PriceMax ?? 10000000)" onchange="document.getElementById('priceDisplay').innerText = new Intl.NumberFormat('vi-VN').format(this.value) + ' VND'; this.form.submit()">
                        <div class="d-flex justify-content-between text-muted small mt-2">
                            <span>0 VND</span>
                            <span id="priceDisplay">@( (Model.PriceMax ?? 10000000).ToString("N0") ) VND</span>
                        </div>
                    </div>
                    
                    <!-- Lọc Chế độ ăn uống -->
                    <div class="hms-filter-section">
                        <h6 class="fw-bold mb-3">Ăn uống & Dị ứng</h6>
                        <div class="form-check mb-2">
                            <input type="checkbox" name="SupportsVeganMeal" value="true" class="form-check-input" @(Model.SupportsVeganMeal==true?"checked":"") id="fv" onchange="this.form.submit()" />
                            <label class="form-check-label small" for="fv">Hỗ trợ ăn chay (Vegan)</label>
                        </div>
                        <div class="form-check mb-2">
                            <input type="checkbox" name="SupportsAllergyRequest" value="true" class="form-check-input" @(Model.SupportsAllergyRequest==true?"checked":"") id="fa" onchange="this.form.submit()" />
                            <label class="form-check-label small" for="fa">Hỗ trợ khách dị ứng</label>
                        </div>
                        <div class="form-check mb-2">
                            <input type="checkbox" name="NoStrongScentAvailable" value="true" class="form-check-input" @(Model.NoStrongScentAvailable==true?"checked":"") id="fn" onchange="this.form.submit()" />
                            <label class="form-check-label small" for="fn">Phòng không mùi nồng</label>
                        </div>
                    </div>

                    <!-- Lọc Kiểu phòng -->
                    <div class="hms-filter-section">
                        <h6 class="fw-bold mb-3">Kiểu phòng & Không gian</h6>
                        <div class="form-check mb-2">
                            <input type="checkbox" name="IsQuietRoom" value="true" class="form-check-input" @(Model.IsQuietRoom==true?"checked":"") id="fq" onchange="this.form.submit()" />
                            <label class="form-check-label small" for="fq">Phòng cách âm / Yên tĩnh</label>
                        </div>
                        <div class="form-check mb-2">
                            <input type="checkbox" name="HasPrivateBathroom" value="true" class="form-check-input" @(Model.HasPrivateBathroom==true?"checked":"") id="fpb" onchange="this.form.submit()" />
                            <label class="form-check-label small" for="fpb">Phòng tắm riêng</label>
                        </div>
                    </div>


                </form>
            </div>
        </div>

        <!-- RIGHT SIDE: RESULTS LIST -->
        <div class="col-lg-9 fade-up">
            <!-- Results Header -->
            <div class="d-flex justify-content-between align-items-end mb-3">
                <div>
                    <h4 class="fw-bold mb-1">@(string.IsNullOrEmpty(Model.City) ? "Tất cả địa điểm" : Model.City)</h4>
                    <span class="text-muted small"><strong>@Model.Results.Count</strong> nơi lưu trú được tìm thấy</span>
                </div>
                <div class="d-flex gap-2">
                    <div class="d-flex align-items-center gap-2">
                        <span class="small fw-semibold text-muted text-nowrap">Xếp theo:</span>
                        <select class="form-select form-select-sm" style="background-color: #E0F2FE; border:none; font-weight:600; color:#0369A1; border-radius:8px;">
                            <option>Độ phổ biến</option>
                            <option>Giá (Thấp đến Cao)</option>
                            <option>Đánh giá cao nhất</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- List of Results -->
            @if (Model.Results.Any())
            {
                foreach (var acc in Model.Results)
                {
                    <div class="hms-list-card">
                        <div class="row g-0">
                            <!-- Image Section -->
                            <div class="col-md-4 hms-card-img-col">
                                <img src="@acc.MainImageUrl" alt="@acc.Name" />
                                <!-- Rating Badge on Image -->
                                @if(acc.AverageRating > 0){
                                    <div class="position-absolute top-0 end-0 m-2">
                                        <div class="hms-score-badge d-flex align-items-center gap-1 shadow-sm">
                                            <i class="bi bi-star-fill text-warning" style="font-size:0.8rem;"></i> @acc.AverageRating.ToString("F1")
                                        </div>
                                    </div>
                                }
                            </div>
                            
                            <!-- Middle Section: Info -->
                            <div class="col-md-5 p-3 d-flex flex-column justify-content-between" style="border-right: 1px dashed var(--border-light);">
                                <div>
                                    <h5 class="fw-bold mb-1" style="color: #111827;">@acc.Name</h5>
                                    <div class="mb-2">
                                        <span class="badge bg-light text-primary border border-primary-subtle me-1">Khách sạn</span>
                                        @if(acc.StarRating.HasValue){
                                            <span style="color:#F59E0B; font-size:0.75rem;">
                                                @for(int i=0; i<acc.StarRating.Value; i++){ <i class="bi bi-star-fill"></i> }
                                            </span>
                                        }
                                    </div>
                                    <p class="text-muted small mb-2"><i class="bi bi-geo-alt text-primary"></i> @acc.City, @acc.Province</p>
                                    
                                    <div class="d-flex flex-wrap gap-1 mb-2">
                                        @if(acc.HasQuietRoom){<span class="badge hms-badge hms-badge-ai"><i class="bi bi-volume-mute"></i> Yên tĩnh</span>}
                                        @if(acc.HasVeganMeal){<span class="badge hms-badge hms-badge-ai"><i class="bi bi-flower1"></i> Ăn chay</span>}
                                        @if(acc.HasAllergySupport){<span class="badge hms-badge hms-badge-ai"><i class="bi bi-shield-check"></i> Dị ứng</span>}
                                        @if(acc.NoStrongScentAvailable){<span class="badge hms-badge hms-badge-ai"><i class="bi bi-wind"></i> Không mùi</span>}
                                        @if(acc.HasPrivateBathroom){<span class="badge hms-badge hms-badge-ai"><i class="bi bi-droplet"></i> Tắm riêng</span>}
                                    </div>
                                </div>
                                
                                <div>
                                    <p class="mb-0 small fw-semibold text-success"><i class="bi bi-check2 text-success"></i> Miễn phí hủy phòng</p>
                                </div>
                            </div>
                            
                            <!-- Right Section: Price & CTA -->
                            <div class="col-md-3 p-3 d-flex flex-column justify-content-between align-items-end text-end bg-white">
                                <div class="w-100 text-end">
                                    @if(acc.ReviewCount > 0){
                                        <div class="mb-3">
                                            <span class="fw-bold" style="color: #0369A1; font-size: 0.95rem;">Rất tốt</span><br/>
                                            <span class="text-muted small">(@acc.ReviewCount đánh giá)</span>
                                        </div>
                                    }
                                    
                                    <div class="hms-price-large">@acc.MinPrice.ToString("N0") <span style="font-size: 1rem; font-weight:700;">VND</span></div>
                                    <div class="hms-tax-info mt-1">Tổng @( (acc.MinPrice).ToString("N0") ) VND<br/>cho 1 phòng<br/>Bao gồm thuế và phí</div>
                                </div>
                                <a asp-action="Details" asp-route-id="@acc.Id" class="btn btn-primary fw-bold px-4 py-2 mt-3 w-100 shadow-sm" style="border-radius: 8px;">Chọn phòng</a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5 bg-white shadow-sm" style="border-radius: var(--r);">
                    <div class="hms-step-icon mx-auto mb-3" style="width:72px;height:72px; background:#F3F4F6; color:#9CA3AF;"><i class="bi bi-search" style="font-size:1.6rem;"></i></div>
                    <h5 class="fw-bold text-muted">Không tìm thấy kết quả</h5>
                    <p class="text-muted small">Hãy thử thay đổi bộ lọc hoặc điểm đến.</p>
                </div>
            }
        </div>
    </div>
</div>
